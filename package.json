{
  "name": "kalshi-bot",
  "productName": "Kalshi Bot",
  "version": "1.0.0",
  "description": "A local-first Kalshi auto-trading desktop app. Whale tracker, momentum scanner and a configurable trading engine. Your API keys never leave your machine.",
  "main": "dist-electron/main.js",
  "license": "MIT",
  "private": true,
  "scripts": {
    "predev": "node scripts/setup-python.mjs",
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.json --noEmit",
    "py:setup": "node scripts/setup-python.mjs",
    "dist": "npm run build && electron-builder"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/react": "^18.2.74",
    "@types/react-dom": "^18.2.24",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "lucide-react": "^0.368.0",
    "postcss": "^8.4.38",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.12.7",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.9",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "com.kalshibot.app",
    "productName": "Kalshi Bot",
    "files": ["dist/**", "dist-electron/**", "resources/**"],
    "directories": { "output": "release" },
    "mac": { "target": ["dmg"], "category": "public.app-category.finance" },
    "win": { "target": ["nsis"] },
    "linux": { "target": ["AppImage"], "category": "Office" },
    "publish": null
  }
}
